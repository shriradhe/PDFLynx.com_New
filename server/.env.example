# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/pdflynx
# For Docker: MONGO_URI=mongodb://mongo:27017/pdflynx
# For Atlas:  MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/pdflynx

# JWT — IMPORTANT: Change this in production!
JWT_SECRET=change_this_to_a_long_random_secret_key_at_least_64_chars
JWT_EXPIRES_IN=7d

# File Management
FILE_TTL_MINUTES=30
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# CORS
CLIENT_URL=http://localhost:5173

# AWS S3 (optional — leave blank to use local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# Redis (optional — for queue system. Set REDIS_ENABLED=false to disable)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
WORKER_CONCURRENCY=3

# Email (optional — leave blank to log emails to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@pdflynx.com

# AI Features (optional — leave blank for mock responses)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small

# Stripe (optional — for subscription billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=
